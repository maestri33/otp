# Servico
SERVICE_NAME=otp
ENV=dev
LOG_LEVEL=INFO
PORT=80

# Banco
DATABASE_URL=sqlite://data/app.db

# Servico externo notify
NOTIFY_BASE_URL=http://10.10.10.157/api/v1

# OTP
OTP_FOOTER=Equipe OTP
OTP_TTL_S=300
OTP_NUM_DIGITS=6
OTP_MAX_ATTEMPTS=3
OTP_ACTIVE=true
