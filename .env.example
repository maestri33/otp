# ============================================================================
# .env.example — copie pra .env e preencha
# ============================================================================
# Servico
SERVICE_NAME=microservice-template
ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO
PORT=90

# Banco — cada servico tem o SEU proprio
# SQLite local (default, zero infra). Tortoise: 2 barras p/ relativo, 3 p/ absoluto.
DATABASE_URL=sqlite://data/app.db
# Quando crescer, troca pra Postgres dedicado deste servico:
# DATABASE_URL=postgres://user:pass@db.proxmox.local:5432/microservice_template

# Redis (cache + pub/sub leve)
REDIS_URL=redis://redis.proxmox.local:6379/0

# RabbitMQ (mensageria entre microservices)
AMQP_URL=amqp://guest:guest@rabbit.proxmox.local:5672/

# Webhooks
WEBHOOK_OUTBOUND_TIMEOUT_S=10

# Claude Code (proxy DeepSeek v4 Pro)
ANTHROPIC_BASE_URL=http://proxy.local:8787
ANTHROPIC_AUTH_TOKEN=troque-isto
CONTEXT7_API_KEY=troque-isto
