# ============================================================================
# .env.example — copie pra .env e preencha
# ============================================================================
# Servico
SERVICE_NAME=otp
ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO
PORT=80

# Banco — cada servico tem o SEU proprio
# SQLite local (default, zero infra). Tortoise: 2 barras p/ relativo, 3 p/ absoluto.
DATABASE_URL=sqlite://data/app.db
# Quando crescer, troca pra Postgres dedicado deste servico:
# DATABASE_URL=postgres://user:pass@db.proxmox.local:5432/microservice_template

# Redis (cache + pub/sub leve)
REDIS_URL=redis://redis.proxmox.local:6379/0

# RabbitMQ (mensageria entre microservices)
AMQP_URL=amqp://guest:guest@rabbit.proxmox.local:5672/

# Servico externo notify
NOTIFY_BASE_URL=http://10.10.10.157/api/v1

# Webhooks
WEBHOOK_OUTBOUND_TIMEOUT_S=10

# Claude Code — DeepSeek v4 Pro (get API key from https://platform.deepseek.com/)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=<seu-deepseek-api-key>
ANTHROPIC_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max
